# Required secrets - generate unique values for production
REFRESH_TOKEN_PEPPER=change-me-in-production-use-secure-random
MFA_ENCRYPTION_KEY_BASE64=change-me-in-production-use-32-random-base64-chars

# JWT keys - generate with: openssl genpkey -algorithm ED25519
JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----
MC4CAQAwBQYDK2VwBCIEI...
-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----
MC4CAQAwBQYDK2VwBCIEI...
-----END PUBLIC KEY-----"

# Optional: bootstrap a default user
BOOTSTRAP_USER_EMAIL=admin@example.com
BOOTSTRAP_USER_PASSWORD=change-me
