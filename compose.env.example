POSTGRES_USER=auth
POSTGRES_PASSWORD=replace_with_local_dev_password
POSTGRES_DB=auth

REDIS_PASSWORD=replace_with_local_dev_password

REFRESH_TOKEN_PEPPER=replace_with_long_random_secret
MFA_ENCRYPTION_KEY_BASE64=replace_with_base64_32_bytes_key

# Prefer file-based key loading in real environments.
JWT_PRIVATE_KEY_PEM=-----BEGIN PRIVATE KEY-----\\nreplace_me\\n-----END PRIVATE KEY-----
JWT_PUBLIC_KEY_PEM=-----BEGIN PUBLIC KEY-----\\nreplace_me\\n-----END PUBLIC KEY-----
JWT_KEY_ID=auth-ed25519-v1
JWT_ISSUER=auth-api
JWT_AUDIENCE=auth-clients

METRICS_BEARER_TOKEN=replace_with_metrics_token
METRICS_ALLOWED_CIDRS=127.0.0.0/8

EMAIL_PROVIDER=noop
EMAIL_DELIVERY_MODE=outbox

ENFORCE_DATABASE_TLS=false
ENFORCE_REDIS_TLS=false
